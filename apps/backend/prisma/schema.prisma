// =============================================
// PRISMA SCHEMA - MatBett Backend
// Adaptado a tipos del frontend
// =============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =============================================
// USUARIOS Y AUTENTICACIÓN
// =============================================

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  hashedPassword String
  name           String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // Relaciones
  promotions        Promotion[]
  deposits          Deposit[]
  betRegistrationBatches BetRegistrationBatch[]
  bets              Bet[]
  refreshTokens     RefreshToken[]
  bookmakerAccounts BookmakerAccount[]

  @@index([email])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

// =============================================
// BOOKMAKER ACCOUNTS
// =============================================

model BookmakerAccount {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  bookmaker         String   // User-defined operator name (sportsbook or exchange)
  accountType       String   @default("SPORTSBOOK")
  accountIdentifier String   // User's username/email/alias for this account

  // Balances
  realBalance       Float    @default(0)
  bonusBalance      Float    @default(0)
  freebetBalance    Float    @default(0)

  // Timestamps
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relaciones
  promotions        Promotion[]
  deposits          Deposit[]
  bets              Bet[]

  @@unique([userId, bookmaker, accountIdentifier])
  @@index([userId])
  @@index([userId, accountType])
  @@map("bookmaker_accounts")
}


// =============================================
// PROMOCIONES
// =============================================

model Promotion {
  id          String  @id @default(cuid())
  name        String
  description String?
  bookmaker   String
  bookmakerAccountId String
  bookmakerAccount BookmakerAccount @relation(fields: [bookmakerAccountId], references: [id], onDelete: Restrict)
  status      String  @default("NOT_STARTED") // "NOT_STARTED", "ACTIVE", "COMPLETED", "EXPIRED"
  timeframe   Json // AbsoluteTimeframe: { mode: "ABSOLUTE", start: Date, end: Date }

  // Campos adicionales del frontend
  cardinality      String @default("SINGLE") // "SINGLE", "MULTIPLE"
  activationMethod String @default("AUTOMATIC") // "AUTOMATIC", "MANUAL", "CLICK", etc.
  totalBalance     Float  @default(0)

  // Timestamps de estado (para timeframes)
  activatedAt DateTime?
  completedAt DateTime?
  expiredAt   DateTime?

  // Auditoría
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relaciones
  phases Phase[]
  rewards Reward[]
  betParticipations BetParticipation[]
  depositParticipations DepositParticipation[]
  // Pool de condiciones de calificacion reutilizables (nivel promocion)
  availableQualifyConditions RewardQualifyCondition[]

  @@index([userId, status])
  @@index([bookmaker])
  @@index([bookmakerAccountId])
  @@map("promotions")
}

// =============================================
// FASES
// =============================================

model Phase {
  id               String  @id @default(cuid())
  name             String
  description      String?
  status           String  @default("NOT_STARTED") // "NOT_STARTED", "ACTIVE", "COMPLETED", "EXPIRED"
  timeframe        Json // Timeframe: AbsoluteTimeframe | RelativeTimeframe
  activationMethod String  @default("AUTOMATIC")
  totalBalance     Float   @default(0)

  // Timestamps de estado (para timeframes)
  activatedAt DateTime?
  completedAt DateTime?
  expiredAt   DateTime?

  // Relaciones
  promotionId String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)


  // Rewards de esta fase
  rewards Reward[]
  betParticipations BetParticipation[]
  depositParticipations DepositParticipation[]

  // Timestamps
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([promotionId, status])
  @@map("phases")
}

// =============================================
// REWARDS
// =============================================

model Reward {
  id                String  @id @default(cuid())
  type              String // "FREEBET", "CASHBACK_FREEBET", "BET_BONUS_ROLLOVER", "BET_BONUS_NO_ROLLOVER", "ENHANCED_ODDS", "CASINO_SPINS"
  value             Float // Valor de la recompensa
  valueType         String  @default("FIXED") // "FIXED", "CALCULATED_FROM_CONDITIONS"
  activationMethod  String  @default("AUTOMATIC")
  claimMethod       String  @default("AUTOMATIC") // "AUTOMATIC", "MANUAL_CLICK", "MANUAL_CODE", "CUSTOMER_SERVICE"
  activationRestrictions String? // Restricciones de activacion/canjeo: opt-in, verificacion, plazos
  claimRestrictions String? // Restricciones de reclamación: timeouts (48h), delays (3 días), condiciones especiales
  withdrawalRestrictions String? // Restricciones de retirada: cancelacion de bono, bloqueo temporal, etc.
  status            String  @default("QUALIFYING") // "QUALIFYING", "PENDING_TO_CLAIM", "CLAIMED", "RECEIVED", "IN_USE", "USED", "EXPIRED"
  totalBalance      Float   @default(0)

  // Timestamps de estado (para timeframes y eventos)
  qualifyConditionsFulfilledAt DateTime?
  claimedAt                    DateTime?
  receivedAt                   DateTime?
  useStartedAt                 DateTime?
  useCompletedAt               DateTime?
  expiredAt                    DateTime?

  // Relaciones
  promotionId String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  phaseId     String
  phase       Phase     @relation(fields: [phaseId], references: [id], onDelete: Cascade)

  // Qualify conditions que este reward usa (pueden ser del pool o propias)
  qualifyConditions RewardQualifyCondition[] @relation("RewardToQualifyConditions")

  // Type-specific fields (JSON embebido - campos específicos por tipo de reward)
  typeSpecificFields Json? // Campos propios de cada tipo:
  // FREEBET: { stakeNotReturned: boolean }
  // Otros tipos: null

  // Usage conditions (JSON embebido - configuración inmutable, 1-to-1)
  usageConditions Json? // Almacena las condiciones de uso según el tipo de reward
  // Ejemplos por tipo:
  // BET_BONUS_ROLLOVER: { multiplier: 5, maxConversionMultiplier: 1, minBetsRequired: 3, oddsRestriction: {...}, ... }
  // FREEBET: { mustUseComplete: true, lockWinningsUntilFullyUsed: false, oddsRestriction: {...}, ... }
  // CASHBACK_FREEBET: { cashbackPercentage: 20, maxCashbackAmount: 100, oddsRestriction: {...}, ... }
  // CASINO_SPINS: { spinsCount: 20, gameTitle: "Gates of Olympus" }

  // Usage tracking (tabla separada - datos mutables, relaciones con bets)
  usageTracking RewardUsageTracking?
  betParticipations BetParticipation[]
  calculationBetParticipations BetParticipation[] @relation("BetParticipationCalculationReward")
  depositParticipations DepositParticipation[]

  // Auditoría
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([promotionId, status])
  @@index([phaseId])
  @@index([type])
  @@map("rewards")
}

// =============================================
// REWARD USAGE TRACKING
// =============================================

model RewardUsageTracking {
  id       String @id @default(cuid())
  rewardId String @unique
  reward   Reward @relation(fields: [rewardId], references: [id], onDelete: Cascade)

  type    String // Cache del reward.type para queries eficientes
  balance Float  @default(0)

  // Progreso específico por tipo (JSON flexible)
  usageData Json // Ejemplos por tipo:
  // BET_BONUS_ROLLOVER: { totalUsed: 50, rolloverProgress: 250, remainingRollover: 250 }
  // FREEBET: { totalUsed: 25, remainingBalance: 25 }
  // CASHBACK_FREEBET: { totalCashback: 15.50 }
  // CASINO_SPINS: { spinsUsed: 10, spinsRemaining: 10, totalWinnings: 32.50 }
  // ENHANCED_ODDS: { oddsUsed: 1 }

  // Relaciones
  betParticipations BetParticipation[]

  // Usage timeline
  startedAt   DateTime?
  completedAt DateTime?
  expiredAt   DateTime?
  failedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([rewardId])
  @@index([type])
  @@map("reward_usage_trackings")
}

// =============================================
// QUALIFY CONDITIONS (Pool reutilizable)
// =============================================

model RewardQualifyCondition {
  id                       String  @id @default(cuid())
  type                     String // "DEPOSIT", "BET", "LOSSES_CASHBACK"
  description              String? // Descripción opcional de la condición
  status                   String  @default("PENDING") // "PENDING", "ACTIVE", "FULFILLED", "FAILED"
  priority                 Int     @default(0)
  balance                  Float   @default(0)

  // Timeframe de la qualify condition
  timeframe Json // Timeframe: AbsoluteTimeframe | RelativeTimeframe

  // Condiciones específicas (JSON para flexibilidad)
  conditions Json // Ejemplos por tipo:
  // DEPOSIT: { minAmount: 50, bonusPercentage: 100, depositCode?: "SPT100" }
  // BET: { targetPercentageOfDeposit?: 50, allowRetries: true, betConditions: {...} }
  // LOSSES_CASHBACK: { cashbackPercentage: 20, maxCashbackAmount: 100, calculationMethod: "NET_LOSS" }

  // Timestamps de estado (para timeframes y anchors)
  startedAt    DateTime? // → QUALIFYING (cuando comienza el periodo de calificación)
  qualifiedAt  DateTime? // → FULFILLED (cuando se cumple la condición)
  failedAt     DateTime? // → FAILED (cuando falla la condición)
  expiredAt    DateTime? // → EXPIRED (cuando expira el periodo)

  // Relacion con promocion (pool)
  promotionId String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  // Relación con rewards que usan esta condición
  rewards Reward[] @relation("RewardToQualifyConditions")

  // Operaciones que participan en esta condición
  depositParticipations DepositParticipation[]
  betParticipations     BetParticipation[]

  // Tracking de progreso (JSON para flexibilidad)
  trackingData Json? // { depositAmount?, betIds?, lossesAmount?, etc. }

  // Auditoría
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([promotionId, status])
  @@index([type])
  @@map("reward_qualify_conditions")
}

// =============================================
// DEPÓSITOS
// =============================================

model Deposit {
  id        String   @id @default(cuid())
  bookmaker String
  bookmakerAccountId String
  bookmakerAccount BookmakerAccount @relation(fields: [bookmakerAccountId], references: [id], onDelete: Restrict)
  amount    Float
  code      String? // Código promocional usado
  date      DateTime

  // Participaciones contextuales (tracking de qualify conditions)
  participations DepositParticipation[]

  // Usuario
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Auditoría
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, bookmakerAccountId])
  @@index([bookmaker])
  @@index([date])
  @@map("deposits")
}

// =============================================
// APUESTAS
// =============================================

model BetRegistrationBatch {
  id                       String   @id @default(cuid())
  userId                   String
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  strategyKind             String
  strategyType             String?
  lineMode                 String?
  mode                     String?
  dutchingOptionsCount     Int?
  hedgeAdjustmentType      String?
  scenarioId               String?
  calculationParticipationId String?
  calculationParticipation BetParticipation? @relation("BatchCalculationParticipation", fields: [calculationParticipationId], references: [id], onDelete: SetNull)
  events                   Json
  profit                   Float
  risk                     Float
  yield                    Float
  bets                     Bet[]
  participations           BetParticipation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, strategyKind])
  @@index([scenarioId])
  @@index([calculationParticipationId])
  @@map("bet_registration_batches")
}

model Bet {
  id                String  @id @default(cuid())
  batchId           String
  batch             BetRegistrationBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  bookmakerAccountId String
  bookmakerAccount  BookmakerAccount @relation(fields: [bookmakerAccountId], references: [id], onDelete: Restrict)
  legRole           String?
  legOrder          Int
  selections        Json
  odds              Float
  stake             Float
  commission        Float   @default(0)
  enhancedOdds      Json?

  // Resultados
  status String @default("PENDING") // "PENDING", "WON", "LOST", "VOID", "CASHOUT"
  profit Float
  risk   Float
  yield  Float

  // Participaciones contextuales
  participations BetParticipation[]

  // Usuario
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Timestamps
  placedAt  DateTime
  settledAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([batchId, legRole])
  @@unique([batchId, legOrder])
  @@index([userId, bookmakerAccountId])
  @@index([batchId])
  @@index([bookmakerAccountId])
  @@map("bets")
}

// =============================================
// BET PARTICIPATIONS
// =============================================

model BetParticipation {
  id        String   @id @default(cuid())
  kind      String // "QUALIFY_TRACKING" | "REWARD_USAGE"

  batchId   String
  batch     BetRegistrationBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  calculationTargetOfBatches BetRegistrationBatch[] @relation("BatchCalculationParticipation")

  betId     String
  bet       Bet      @relation(fields: [betId], references: [id], onDelete: Cascade)

  promotionId String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  phaseId   String?
  phase     Phase?     @relation(fields: [phaseId], references: [id], onDelete: SetNull)

  rewardId  String?
  reward    Reward?    @relation(fields: [rewardId], references: [id], onDelete: Restrict)
  rewardIds String[]   @default([])
  calculationRewardId String?
  calculationReward Reward? @relation("BetParticipationCalculationReward", fields: [calculationRewardId], references: [id], onDelete: Restrict)
  rewardType String

  qualifyConditionId String?
  qualifyCondition   RewardQualifyCondition? @relation(fields: [qualifyConditionId], references: [id], onDelete: SetNull)

  usageTrackingId String?
  usageTracking   RewardUsageTracking? @relation(fields: [usageTrackingId], references: [id], onDelete: SetNull)
  contributesToTracking Boolean @default(false)
  stakeAmount          Float?
  rolloverContribution Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([batchId])
  @@index([betId])
  @@index([kind, promotionId])
  @@index([rewardId, kind])
  @@index([calculationRewardId])
  @@index([phaseId])
  @@index([qualifyConditionId])
  @@index([usageTrackingId])
  @@map("bet_participations")
}

// =============================================
// DEPOSIT PARTICIPATIONS
// =============================================

model DepositParticipation {
  id        String   @id @default(cuid())
  role      String // "QUALIFY_TRACKING"

  depositId String
  deposit   Deposit @relation(fields: [depositId], references: [id], onDelete: Cascade)

  promotionId String
  promotion   Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  phaseId   String?
  phase     Phase?     @relation(fields: [phaseId], references: [id], onDelete: SetNull)

  rewardId  String?
  reward    Reward?    @relation(fields: [rewardId], references: [id], onDelete: SetNull)

  qualifyConditionId String
  qualifyCondition   RewardQualifyCondition @relation(fields: [qualifyConditionId], references: [id], onDelete: Cascade)

  countsAsQualification Boolean?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([depositId])
  @@index([role, promotionId])
  @@index([phaseId])
  @@index([rewardId])
  @@index([qualifyConditionId])
  @@map("deposit_participations")
}

// =============================================
// CONFIGURACIÓN DEL SISTEMA
// =============================================

model SystemConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       Json
  description String?
  updatedAt   DateTime @updatedAt

  @@map("system_config")
}
